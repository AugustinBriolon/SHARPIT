generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ActivityType {
  RUN
  BIKE
  SWIM
  STRENGTH
  TRIATHLON
  OTHER
}

enum GoalHorizon {
  LONG_TERM
  MEDIUM_TERM
  SHORT_TERM
  WEEKLY
  MONTHLY
  YEARLY
}

enum GoalKind {
  RACE
  METRIC
}

// Priorité d'une course (standard triathlon) :
// A = objectif principal de la saison, B = course intermédiaire, C = test / entraînement.
enum GoalPriority {
  A
  B
  C
}

enum SessionIntensity {
  RECOVERY
  ENDURANCE
  TEMPO
  THRESHOLD
  VO2MAX
  RACE
}

enum PhysicalCategory {
  PAIN // douleur
  INJURY // blessure
  MOBILITY // mobilité / souplesse
  POSTURE // posture / déséquilibre (bassin, pieds...)
  OTHER
}

enum BodySide {
  LEFT
  RIGHT
  BILATERAL
  NA
}

enum PhysicalStatus {
  ACTIVE // en cours
  MONITORING // sous surveillance
  RESOLVED // résolue
}

// ─── Physical Health Engine (Phase 1) ───────────────────────────────────────

enum ConditionScope {
  LOCALIZED
  SYSTEMIC
}

enum ConditionType {
  PAIN
  INJURY
  DISCOMFORT
  MOBILITY_LIMITATION
  POSTURE_ISSUE
  MUSCULAR_TIGHTNESS
  JOINT_STIFFNESS
  INSTABILITY
  RECURRING_PHYSICAL
  OTHER
}

enum ConditionStatus {
  NEW
  ACTIVE
  IMPROVING
  STABLE
  WORSENING
  RESOLVED
  RECURRENT
}

enum EpisodeStatus {
  ACTIVE
  IMPROVING
  STABLE
  WORSENING
  RESOLVED
}

enum ObservationContext {
  BEFORE_SESSION
  DURING_SESSION
  AFTER_SESSION
  MORNING_CHECKIN
  EVENING_CHECKIN
  MANUAL
  COACH_CONVERSATION
  INTEGRATION
  LEGACY_MIGRATION
}

enum ObservationSource {
  ATHLETE
  COACH_AI
  SYSTEM_MIGRATION
  INTEGRATION
}

enum FunctionalImpact {
  NONE
  MILD
  MODERATE
  LIMITING
  STOPPED
}

enum TrainingCapacityLevel {
  FULL
  REDUCED
  LIMITED
  UNABLE
}

enum KnowledgeHypothesisType {
  TRIGGER
  RECOVERY_DURATION
  RECURRENCE_PATTERN
  OTHER
}

enum KnowledgeConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

enum PlanPhase {
  BASE
  BUILD
  PEAK
  TAPER
  RACE
}

enum TrainingPlanStatus {
  ACTIVE
  ARCHIVED
}

model Activity {
  id       String       @id @default(cuid())
  type     ActivityType
  date     DateTime
  title    String?
  duration Int?
  rpe      Int?
  feeling  String?
  notes    String?
  weather  String?
  load     Float?

  source   String  @default("manual") // manual | garmin | strava | both
  stravaId String? @unique
  garminId String? @unique

  /// Jambes et transitions d'un multisport Garmin (natation, T1, vélo, T2, course…)
  multisportLegs Json?

  runMetrics     RunMetrics?
  bikeMetrics    BikeMetrics?
  swimMetrics    SwimMetrics?
  strengthSets   StrengthSet[]
  stream         ActivityStream?
  plannedSession PlannedSession?
  goalAchievements GoalAchievement[]
  conditionObservations ConditionObservation[]

  /// Analyse narrative coach (figée une fois générée)
  narrativeAnalysis   Json?
  narrativeAnalyzedAt DateTime?

  /// Lieu observé (reverse geocode GPS après séance)
  observedLocationLabel String?
  observedLocationLat   Float?
  observedLocationLng   Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([type])
}

model AthleteProfile {
  id                       String @id @default("default")
  heightCm                 Int? // taille (cm) — comparaisons composition (IMC, etc.)
  birthDate                DateTime? @db.Date // date de naissance — âge calculé dynamiquement
  ftpW                     Int? // FTP vélo (W)
  maxHr                    Int? // FC max (bpm)
  lthr                     Int? // FC seuil lactique (bpm)
  runThresholdPaceSecPerKm Float? // allure seuil (s/km)
  vo2maxRunning            Int? // VO2max course
  vo2maxCycling            Int? // VO2max vélo
  thresholdsSyncedAt       DateTime? // dernier import depuis Garmin

  context String? @db.Text // contexte libre éditable (dispos, contraintes pro, préférences) injecté dans le coach IA

  sleepTargetMinutes    Int? // durée de sommeil visée (min)
  sleepBedtimeTargetMin Int? // heure de coucher visée (minutes depuis minuit, locale)

  homeLocationLabel String?
  homeLocationLat   Float?
  homeLocationLng   Float?

  thresholdSnapshots AthleteThresholdSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AthleteThresholdSnapshot {
  id                       String         @id @default(cuid())
  profileId                String         @default("default")
  profile                  AthleteProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  source                   String // estimated | garmin | manual
  ftpW                     Int?
  lthr                     Int?
  runThresholdPaceSecPerKm Float?

  createdAt DateTime @default(now())

  @@index([profileId])
  @@index([createdAt])
}

model ActivityStream {
  id         String   @id @default(cuid())
  activityId String   @unique
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  available Boolean @default(false) // false = pas de GPS/streams (manuel, piscine, erreur définitive)
  polyline  String? // polyline encodée (fallback carte)
  data      Json? // séries temporelles : { time, distance, altitude, heartrate, watts, cadence, velocity, latlng }

  fetchedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarminAccount {
  id          String    @id @default("default")
  displayName String?
  fullName    String?
  oauth1Token Json
  oauth2Token Json
  lastSyncAt         DateTime?
  lastActivitySyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StravaAccount {
  id           String    @id @default("default")
  athleteId    String    @unique
  firstName    String?
  lastName     String?
  avatarUrl    String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?
  lastSyncAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GoogleAccount {
  id           String   @id @default("default")
  email        String?
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?

  // Calendrier cible où le coach écrit les séances (ex: calendrier "SPORT")
  targetCalendarId   String?
  targetCalendarName String?
  // Calendriers Google masqués dans la page Calendrier de l'app
  hiddenCalendarIds String[] @default([])
  // Fuseau horaire utilisé pour créer les événements
  timeZone String @default("Europe/Paris")

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RenphoAccount {
  id           String    @id @default("default")
  email        String
  passwordEnc  String
  displayName  String?
  renphoUserId String?
  lastSyncAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WithingsAccount {
  id             String    @id @default("default")
  withingsUserId String
  accessToken    String
  refreshToken   String
  expiresAt      DateTime
  displayName    String?
  lastSyncAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RunMetrics {
  id         String   @id @default(cuid())
  activityId String   @unique
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  distanceM      Float?
  elevationM     Float?
  paceSecPerKm   Float?
  avgHr          Int?
  avgPower       Float?
  cadence        Int?
  shoes          String?
}

model BikeMetrics {
  id         String   @id @default(cuid())
  activityId String   @unique
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  ftpPercent      Float?
  normalizedPower Float?
  intensityFactor Float?
  tss             Float?
  avgCadence      Int?
  avgPower        Float?
  elevationM      Float?
  calories        Int?
  bikeName        String?
}

model SwimMetrics {
  id         String   @id @default(cuid())
  activityId String   @unique
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  distanceM         Float?
  sets              Int?
  cssSecPer100m     Float?
  avgPaceSecPer100m Float?
  swolf             Float?
  drills            String?
}

model StrengthSet {
  id         String   @id @default(cuid())
  activityId String
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  exercise String
  sets     Int
  reps     Int
  durationSec Int?
  weightKg Float?
  rpe      Int?
  restSec  Int?
  videoUrl String?
  notes    String?
  order    Int      @default(0)

  @@index([activityId])
}

model DailyHealth {
  id   String   @id @default(cuid())
  date DateTime @unique @db.Date

  sleepMinutes  Int?
  napMinutes    Int? // sieste (Garmin napTimeSeconds, hors sommeil nocturne)
  hrv           Int?
  restingHr     Int?
  weightKg      Float?
  calories      Int?
  recoveryScore Int? // Garmin Training Readiness (0-100)
  stress        Int? // stress moyen sur la journée
  mood          String?

  // Sommeil détaillé (Garmin)
  sleepScore       Int? // score de sommeil Garmin (0-100)
  sleepDeepMin     Int? // sommeil profond (min)
  sleepLightMin    Int? // sommeil léger (min)
  sleepRemMin      Int? // sommeil paradoxal / REM (min)
  sleepAwakeMin    Int? // éveil pendant la nuit (min)
  sleepBedtimeMin  Int? // heure de coucher en minutes depuis minuit (heure locale)
  sleepWakeMin     Int? // heure de réveil en minutes depuis minuit (heure locale)
  sleepRespiration Float? // respiration moyenne (resp/min)
  sleepAvgStress   Int? // stress moyen pendant le sommeil
  sleepScoreFeedback String? // code feedback qualité Garmin

  // Recovery (Garmin)
  readinessLevel    String? // LOW / MODERATE / HIGH ...
  readinessFeedback String? // code feedback court Garmin
  readinessFactors  Json? // détail des facteurs (sommeil, hrv, charge...)
  hrvStatus         String? // BALANCED / UNBALANCED_LOW / ...
  hrvBaselineLow    Int? // borne basse de la zone équilibrée
  hrvBaselineHigh   Int? // borne haute de la zone équilibrée
  bodyBattery       Int? // niveau d'énergie le plus haut du jour

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BodyCompositionSource {
  RENPHO
  WITHINGS
}

model BodyCompositionMeasurement {
  id         String                @id @default(cuid())
  source     BodyCompositionSource
  externalId String
  measuredAt DateTime

  weightKg           Float?
  bmi                Float?
  bodyFatPct         Float?
  waterPct           Float?
  musclePct          Float?
  boneKg             Float?
  bmr                Float?
  visceralFat        Float?
  proteinPct         Float?
  bodyAge            Int?
  subcutaneousFatPct Float?
  skeletalMusclePct  Float?
  fatFreeWeightKg    Float?
  heartRate          Int?

  // Withings Body Scan — cardio & nerve health
  vascularAgeYears      Int?
  pulseWaveVelocity     Float?
  vo2Max                Float?
  nerveHealthScore      Float?
  nerveHealthLeft       Float?
  nerveHealthRight      Float?
  nerveResponseScore    Float?
  skinConductance       Float?
  metabolicAge          Int?
  hydrationKg           Float?
  fatMassKg               Float?
  extracellularWaterKg    Float?
  intracellularWaterKg    Float?
  withingsExtras          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, externalId])
  @@index([measuredAt])
  @@index([source, measuredAt])
}

model Goal {
  id           String       @id @default(cuid())
  title        String
  kind         GoalKind     @default(METRIC)
  horizon      GoalHorizon?
  metricKey    String?
  startValue   Float?
  currentValue Float?
  targetValue  Float?
  unit         String?
  lowerIsBetter Boolean     @default(false)
  targetDate   DateTime?
  location     String?
  achieved     Boolean      @default(false)
  notes        String?

  // Détails spécifiques aux courses (kind = RACE) — tous optionnels :
  priority          GoalPriority? // importance A/B/C dans la périodisation
  raceFormat        String? // format / distance (ex. "Half Ironman", "10 km", "Marathon")
  targetPerformance String? // objectif visé (ex. "Sub 5h00", "Top 10", "Terminer")

  plannedSessions PlannedSession[]
  trainingPlans   TrainingPlan[]
  achievements    GoalAchievement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
  @@index([targetDate])
}

model GoalAchievement {
  id          String    @id @default(cuid())
  goalId      String
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  activityId  String?
  activity    Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  source      String // auto | manual
  value       Float?
  targetValue Float?
  /// Période ISO (2026-W27, 2026-07, 2026) ou _performance pour chrono distance
  periodKey   String

  achievedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([goalId, periodKey])
  @@index([goalId, achievedAt])
  @@index([activityId])
}

model TrainingPlan {
  id          String             @id @default(cuid())
  goalId      String?
  goal        Goal?              @relation(fields: [goalId], references: [id], onDelete: SetNull)
  raceDate    DateTime           @db.Date
  startDate   DateTime           @db.Date
  status      TrainingPlanStatus @default(ACTIVE)
  baselineCtl Int?
  summary     String?            @db.Text

  weeks PlanWeek[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([raceDate])
}

model PlanWeek {
  id          String       @id @default(cuid())
  planId      String
  plan        TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekStart   DateTime     @db.Date
  weekIndex   Int
  phase       PlanPhase
  targetLoad  Int // TSS cible de la semaine
  targetHours Float?
  focus       String?
  isDeload    Boolean      @default(false)

  @@unique([planId, weekIndex])
  @@index([planId])
  @@index([weekStart])
}

model PhysicalNote {
  id          String           @id @default(cuid())
  category    PhysicalCategory @default(PAIN)
  status      PhysicalStatus   @default(ACTIVE)
  title       String // ex: "Tendinite genou droit"
  bodyPart    String? // ex: "Genou", "Bassin", "Pied"
  side        BodySide         @default(NA)
  severity    Int? // 0-10 (sévérité actuelle)
  description String?
  affectsTraining Boolean      @default(true) // injecté dans le contexte coach

  startDate  DateTime  @default(now())
  resolvedAt DateTime?

  checkins PhysicalCheckin[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model PhysicalCheckin {
  id     String       @id @default(cuid())
  noteId String
  note   PhysicalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  date     DateTime @default(now())
  severity Int? // 0-10 au moment du point de contrôle
  comment  String?

  createdAt DateTime @default(now())

  @@index([noteId])
  @@index([date])
}

/// Persistent physical condition — core of the Physical Health Engine.
/// Never deleted. Resolved conditions remain in physiological history.
model Condition {
  id                    String          @id @default(cuid())
  scope                 ConditionScope
  type                  ConditionType
  bodyRegion            String
  side                  BodySide        @default(NA)
  label                 String
  diagnosis             String?
  status                ConditionStatus @default(NEW)
  severity              Float           @default(0)
  confidence            Float           @default(0.5)
  affectsTraining       Boolean         @default(true)
  startedAt             DateTime        @default(now())
  resolvedAt            DateTime?
  lastObservationAt     DateTime?
  recurrenceCount       Int             @default(0)
  observationCount      Int             @default(0)
  estimatedRecoveryDays Int?
  primaryTriggerManual  String?

  /// Idempotent link to legacy PhysicalNote during migration.
  legacyPhysicalNoteId String? @unique

  episodes             ConditionEpisode[]
  observations         ConditionObservation[]
  functionalCapacities FunctionalCapacity[]
  knowledge            ConditionKnowledge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([bodyRegion, side])
}

model ConditionEpisode {
  id                    String        @id @default(cuid())
  conditionId           String
  condition             Condition     @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  episodeNumber         Int
  status                EpisodeStatus @default(ACTIVE)
  startedAt             DateTime
  resolvedAt            DateTime?
  peakSeverity          Float?
  estimatedRecoveryDays Int?
  triggerHypothesis     String?

  observations ConditionObservation[]

  @@unique([conditionId, episodeNumber])
  @@index([conditionId])
}

/// Point-in-time evidence. Never replaces condition state directly.
model ConditionObservation {
  id               String             @id @default(cuid())
  conditionId      String?
  condition        Condition?         @relation(fields: [conditionId], references: [id], onDelete: SetNull)
  episodeId        String?
  episode          ConditionEpisode?  @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  observedAt       DateTime           @default(now())
  context          ObservationContext
  source           ObservationSource  @default(ATHLETE)
  symptomPresent   Boolean
  severityReported Int?
  functionalImpact FunctionalImpact?
  bodyRegion       String
  side             BodySide           @default(NA)
  type             ConditionType
  comment          String?
  activityId       String?
  activity         Activity?          @relation(fields: [activityId], references: [id], onDelete: SetNull)
  plannedSessionId String?
  plannedSession   PlannedSession?    @relation(fields: [plannedSessionId], references: [id], onDelete: SetNull)
  trainingDayId    String?
  externalId       String?            @unique

  legacyPhysicalCheckinId String? @unique

  functionalCapacities FunctionalCapacity[]

  createdAt DateTime @default(now())

  @@index([conditionId, observedAt])
  @@index([activityId])
  @@index([plannedSessionId])
  @@index([observedAt])
}

/// Functional capacity distinct from pain severity.
model FunctionalCapacity {
  id               String                @id @default(cuid())
  conditionId      String
  condition        Condition             @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  observationId    String?
  observation      ConditionObservation? @relation(fields: [observationId], references: [id], onDelete: SetNull)
  assessedAt       DateTime              @default(now())
  painSeverity     Int?
  trainingCapacity TrainingCapacityLevel
  comment          String?

  @@index([conditionId, assessedAt])
}

/// Personalized hypotheses — athlete-specific, never statistical population models.
model ConditionKnowledge {
  id              String                   @id @default(cuid())
  conditionId     String
  condition       Condition                @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  hypothesisType  KnowledgeHypothesisType
  description     String
  confidence      KnowledgeConfidenceLevel @default(LOW)
  evidenceCount   Int                      @default(0)
  isInferred      Boolean                  @default(false)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([conditionId])
}

model DailyBriefing {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  content     String   @db.Text // bilan du jour en markdown généré par le coach IA
  readiness   Int? // readiness Garmin du jour au moment de la génération
  generatedAt DateTime @default(now())

  @@index([date])
}

model WeeklyReview {
  id          String   @id @default(cuid())
  weekStart   DateTime @unique @db.Date // lundi de la semaine concernée
  content     String   @db.Text // rétro hebdo en markdown générée par le coach IA
  stats       Json? // statistiques de la semaine (volume, conformité, sommeil...)
  generatedAt DateTime @default(now())

  @@index([weekStart])
}

model PerformanceRecord {
  id            String   @id @default(cuid())
  group         String // "run" | "bike" | "swim" | "power" | "run-best"
  category      String // clé unique du record, ex: "run-distance", "power-300", "run-best-5000"
  label         String
  rank          Int // 1 = meilleur (top 5)
  value         Float // valeur brute pour le tri/comparaison
  displayValue  String // valeur formatée pour l'affichage
  sublabel      String?
  activityId    String? // séance à l'origine du record (lien)
  activityDate  DateTime
  activityTitle String?
  createdAt     DateTime @default(now())

  @@unique([category, rank])
  @@index([group])
}

// ─────────────────────────────────────────────────────────────────────────────
// Observation Engine — primary store
// ─────────────────────────────────────────────────────────────────────────────
//
// All incoming data passes through the Observation Engine and lands here.
// Each row represents one normalized, validated observation.
//
// The `data` JSONB column holds the type-specific fields (everything not already
// captured by the indexed columns). Date fields inside `data` are stored as
// ISO-8601 strings and deserialized back by the repository.
//
// Legacy tables (Activity, DailyHealth, BodyCompositionMeasurement, PhysicalNote)
// remain active during the migration period. They will be removed once all
// read paths have been ported to consume Observation directly.

model Observation {
  id            String   @id          // UUID assigned by the engine
  athleteId     String   @default("default")
  type          String               // ObservationType literal
  source        String               // ObservationSource literal
  timestamp     DateTime             // when the observation was physically recorded
  receivedAt    DateTime             // when SHARPIT received it
  trainingDayId String               // YYYY-MM-DD in athlete's timezone
  quality       String               // ObservationQuality literal
  qualityFlags  Json     @default("[]") // QualityFlag[]
  normalizedAt  DateTime
  externalId    String?              // garminId | stravaId | renphoId (for dedup)
  data          Json                 // type-specific fields (JSONB)

  createdAt     DateTime @default(now())

  @@index([athleteId, type])
  @@index([athleteId, trainingDayId])
  @@index([type, externalId])
  @@index([timestamp])
}

// ─────────────────────────────────────────────────────────────────────────────
// Feature Extraction Layer — Feature Set store
// ─────────────────────────────────────────────────────────────────────────────
//
// Each row represents one computed (or pending) FeatureSetRecord.
// Categories: SESSION | LOAD | RECOVERY | BODY | CONDITION
//
// Scoping:
//   SESSION category  → sessionObsId is set (one record per session)
//   BODY category     → sessionObsId is set (reused for observationId)
//   All other cats    → trainingDayId is the scope key
//
// Versioning: version is monotonically increasing per (athleteId, category, scope).
// Old versions are retained for audit. Only the latest COMPUTED version is canonical.
//
// The data column holds the category-specific FeatureSet payload as JSONB.
// Confidence and algorithmId are also persisted for auditability.

model FeatureSet {
  id             String    @id          // UUID assigned by FeatureEngine
  athleteId      String    @default("default")
  category       String                 // 'SESSION' | 'LOAD' | 'RECOVERY' | 'BODY' | 'CONDITION'
  trainingDayId  String?                // YYYY-MM-DD (null only for legacy compat — always set in v1)
  sessionObsId   String?                // Observation.id — set for SESSION and BODY categories
  version        Int       @default(1) // monotonically increasing
  status         String                 // 'PENDING' | 'COMPUTING' | 'COMPUTED' | 'INVALIDATED'
  confidence     Float
  algorithmId    String                 // e.g. 'session-features-v1'
  data           Json                   // FeatureSet payload
  sourceObsIds   String[]  @default([]) // Observation IDs that contributed
  computedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([athleteId, category, trainingDayId])
  @@index([athleteId, category, sessionObsId])
  @@index([athleteId, trainingDayId])
  @@index([athleteId, status])
  @@index([sessionObsId])
}

// ─────────────────────────────────────────────────────────────────────────────
// INFERENCE LAYER — Digital Twin + Decision Records
// ─────────────────────────────────────────────────────────────────────────────

/**
 * One Digital Twin per athlete.
 * Mutable — updated in place by the Inference Orchestrator after each model run.
 *
 * The `recoveryState` column stores the complete RecoveryState JSON.
 * Future models add new nullable columns (e.g. fatigueState) without
 * touching existing data.
 */
model DigitalTwin {
  id             String    @id @default(cuid())
  athleteId      String    @unique
  recoveryState   Json?     // RecoveryState | null
  fatigueState    Json?     // FatigueState | null  (Fatigue Intelligence v1)
  adaptationState Json?     // AdaptationState | null  (Adaptation Intelligence v1)
  reasoningState  Json?     // ReasoningState | null   (Reasoning Engine v1)
  physicalHealthState Json? // PhysicalHealthState | null (Physical Health v1)
  environmentalStressState Json? // EnvironmentalStress | null (Environment v1.1)
  environmentalImpactState Json? // EnvironmentalImpact | null (Environment v1.1)
  environmentalStateMeta Json? // EnvironmentalStateMeta | null (rebuild metadata)
  updatedAt       DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@index([athleteId])
}

/// Immutable environmental evidence — source of truth for environmental inference.
/// Twin environmental columns are a rebuildable cache derived from these records.
model EnvironmentalObservationRecord {
  id               String   @id
  recordVersion    String
  athleteId        String
  dimension        String
  payload          Json
  observedAt       DateTime
  receivedAt       DateTime
  ingestedAt       DateTime
  trainingDayId    String?
  temporalScope    String
  intervalStart    DateTime?
  intervalEnd      DateTime?
  exposure         String
  location         Json
  source           String
  providerId       String?
  externalId       String?
  providerSnapshot Json
  fieldQuality     Json
  aggregateQuality String
  confidence       Float
  supersededBy     String?

  @@index([athleteId, trainingDayId])
  @@index([athleteId, observedAt])
  @@index([supersededBy])
}

/**
 * Immutable audit trail of every inference pass.
 * Created when any model runs — never updated, never deleted.
 *
 * Stores the complete inference snapshot (signals, state update, decision,
 * recommendation, explanation) for auditability and historical replay.
 *
 * Per ADR-004: ephemeral Signals are embedded here, NOT persisted independently.
 */
model DecisionRecord {
  id              String    @id
  athleteId       String
  trainingDayId   String
  modelId         String    // 'recovery-synthesis-v1'
  modelVersion    String    // 'v1'
  confidence      Float
  signals         Json      // { autonomicBalance, sleepAdequacy, ... }
  stateUpdate     Json      // the RecoveryState written to Digital Twin
  decision        Json      // { verdict, recommendedIntensity, rationale }
  recommendation  Json      // { type, title, summary, keyEvidence }
  explanation     String    // human-readable explanation text
  inputSummary    Json      // key feature values used for audit/replay
  computedAt      DateTime
  createdAt       DateTime  @default(now())

  @@index([athleteId, trainingDayId])
  @@index([athleteId, modelId])
  @@index([computedAt])
}

/**
 * Latest Athlete Snapshot per training day — canonical product state.
 * Each regeneration replaces the row; snapshotId fingerprints inputs for idempotency.
 */
model AthleteSnapshotRecord {
  id            String   @id @default(cuid())
  athleteId     String
  trainingDayId String
  snapshotId    String
  payload       Json
  generatedAt   DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([athleteId, trainingDayId])
  @@index([snapshotId])
  @@index([generatedAt])
}

model Conversation {
  id        String   @id @default(cuid())
  title     String   @default("Nouvelle conversation")
  // Historique complet des messages UI (UIMessage[] du AI SDK), sérialisé en JSON.
  messages  Json     @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

model PlannedSession {
  id          String            @id @default(cuid())
  type        ActivityType
  date        DateTime          @db.Date
  startTime   String? // heure de début planifiée "HH:mm" (locale) — choisie pour caser la séance dans l'agenda Google
  title       String?
  description String?
  durationMin Int? // durée prévue en minutes
  load        Float? // charge / TSS prévue
  intensity   SessionIntensity?
  completed   Boolean           @default(false)

  /// Contextual intention — athlete-declared (not engine output).
  exposureSetting String? // INDOOR | OUTDOOR | UNKNOWN
  locationLabel   String?
  locationLat     Float?
  locationLng     Float?
  locationType    String? // ROAD | TRAIL | TRAINER | POOL | GYM | TRACK | UNKNOWN
  /// Cached PlannedSessionContext projection (engine outputs + advisories).
  environmentContext   Json?
  environmentContextAt DateTime?

  goalId String?
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

  // Brick / multisport : les jambes d'un même enchaînement (ex. vélo→course)
  // partagent un brickGroupId. brickOrder donne l'ordre des jambes (0 = première).
  // Chaque jambe reste une séance autonome (un sport, une activité liée, une analyse).
  brickGroupId String?
  brickOrder   Int?

  // Réalisation : activité Strava/Garmin liée + analyse IA prévu vs réalisé
  activityId String?   @unique
  activity   Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)
  analysis   Json? // { complianceScore, verdict, summary, remarks[], recommendation }
  analyzedAt DateTime?
  conditionObservations ConditionObservation[]

  // Lien vers l'événement créé dans Google Calendar (calendrier SPORT)
  googleEventId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([brickGroupId])
}

model AthleteTravelContext {
  id            String   @id @default(cuid())
  label         String?
  locationLabel String
  locationLat   Float
  locationLng   Float
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([startDate, endDate])
}

// Analyse globale d'un brick (enchaînement multisport) : agrège les jambes
// pour évaluer transitions, dérive cardiaque vélo→course et gestion d'ensemble.
// Une analyse par brickGroupId (les jambes gardent par ailleurs leur analyse
// individuelle dans PlannedSession.analysis).
model BrickAnalysis {
  brickGroupId String   @id
  content      Json // { overallScore, summary, transition, remarks[], recommendation }
  generatedAt  DateTime @default(now())
}
