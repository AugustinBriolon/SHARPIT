{
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/sync",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/sync",
      "schedule": "0 18 * * *"
    }
  ],
  "functions": {
    "src/app/api/cron/sync/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/renpho/sync/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/withings/sync/route.ts": {
      "maxDuration": 300
    }
  }
}
