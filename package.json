{
  "name": "sharpit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "yarn && next dev -H 0.0.0.0",
    "build": "prisma generate && next build --webpack",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "db:migrate:deploy": "tsx scripts/repair-failed-migrations.ts && prisma migrate deploy",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next out build coverage .vercel node_modules/.cache tsconfig.tsbuildinfo next-env.d.ts public/sw.js public/sw.js.map",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tsx src/core/benchmarks/cli.ts",
    "benchmark:json": "tsx src/core/benchmarks/cli.ts --json",
    "benchmark:compare": "tsx src/core/benchmarks/cli.ts v1 v2",
    "prepare": "node -e \"process.exit(process.env.CI||process.env.VERCEL?0:1)\" || husky",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:clean:activities": "tsx scripts/clean-activities.ts",
    "db:backfill:narratives": "tsx scripts/backfill-activity-narratives.ts",
    "db:evaluate-decision-outcomes": "tsx scripts/evaluate-decision-outcomes.ts",
    "db:migrate:physical-health": "tsx scripts/migrate-physical-health-phase1.ts",
    "db:studio": "prisma studio",
    "db:up": "docker compose up -d",
    "db:migrate-neon": "bash scripts/migrate-to-neon.sh"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.5",
    "@base-ui/react": "^1.6.0",
    "@clerk/localizations": "^4.11.0",
    "@clerk/nextjs": "^7.5.9",
    "@clerk/themes": "2.4.57",
    "@flow-js/garmin-connect": "^1.6.17",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@serwist/next": "^9.5.11",
    "@tanstack/react-query": "^5.101.2",
    "ai": "^7.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.9.0",
    "remark-gfm": "^4.0.1",
    "serwist": "^9.5.11",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.0",
    "@next/eslint-plugin-next": "^16.2.9",
    "@serwist/cli": "^9.5.11",
    "@tailwindcss/postcss": "^4",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-css-order": "^2.2.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6.19.3",
    "sharp": "^0.35.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "packageManager": "yarn@4.14.1",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,scss,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  }
}
